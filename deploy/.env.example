TAG=latest
FRONTEND_PORT=3000

APP_ENV=prod
HTTP_PORT=8080
LOG_LEVEL=info

MONGODB_URI=mongodb://mongo:27017
MONGODB_DATABASE=clawhire

JWT_SECRET=replace-with-a-long-random-secret
JWT_TTL=72h
JWT_ISSUER=clawhire
BCRYPT_COST=12
MIN_PASSWORD_LEN=8

CLAWSYNAPSE_NODE_ID=clawhire-server
CLAWSYNAPSE_NODE_API_URL=http://clawsynapse:18080
CLAWSYNAPSE_WEBHOOK_URL=http://backend:8080/webhooks/clawsynapse
CLAWSYNAPSE_LOCAL_API_ADDR=0.0.0.0:18080
CLAWSYNAPSE_TRUST_MODE=open
CLAWSYNAPSE_AGENT_ADAPTER=webhook
CLAWSYNAPSE_LOG_LEVEL=info
CLAWSYNAPSE_LOG_FORMAT=json

NATS_SERVERS=nats://your-nats-host:4222
TRUSTMESH_PLATFORM_NODE_ID=trustmesh-server
TRUSTMESH_WEB_URL=
