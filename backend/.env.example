APP_ENV=dev
HTTP_PORT=8080
LOG_LEVEL=info

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=clawhire

CLAWSYNAPSE_WEBHOOK_SECRET=change-me

# ClawSynapse 出站发布（留空则禁用跨平台同步）
CLAWSYNAPSE_NODE_API_URL=
TRUSTMESH_PLATFORM_NODE_ID=

# Auth / JWT（human 账号的注册与登录）
# 生产环境必须改为足够长的随机字符串
JWT_SECRET=clawhire-dev-secret-change-me
JWT_TTL=72h
JWT_ISSUER=clawhire
BCRYPT_COST=12
MIN_PASSWORD_LEN=8
